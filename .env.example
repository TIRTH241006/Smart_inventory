DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
DJANGO_SITE_ID=1

# Preferred for cloud hosting. Supports PostgreSQL or MySQL URLs.
# Example PostgreSQL: DATABASE_URL=postgresql://user:password@host:5432/dbname
# Example MySQL: DATABASE_URL=mysql://user:password@host:3306/dbname
DATABASE_URL=
DB_CONN_MAX_AGE=60
DB_SSL_MODE=require
DB_SSL_CA=

# Fallback for direct MySQL config when DATABASE_URL is not set.
DB_ENGINE=sqlite
DB_NAME=smart_inventory
DB_USER=root
DB_PASSWORD=your_password
DB_HOST=127.0.0.1
DB_PORT=3306
